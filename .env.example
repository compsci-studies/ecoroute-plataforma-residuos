PORT=5001
NODE_ENV=development
APP_TIMEZONE=America/Sao_Paulo

MONGO_URL=mongodb://localhost:27017/ecoroute
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
CRON_SECRET=replace-with-a-long-random-secret

FRONTEND_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
BACKEND_URL=http://localhost:5001
ML_SERVICE_URL=http://localhost:8000

CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# Local email delivery. Used when BREVO_API_KEY and BREVO_SENDER_EMAIL are empty.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
FROM_EMAIL=your-email@gmail.com

# Hosted email delivery through HTTPS. Configure these on Render for production.
BREVO_API_KEY=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=EcoRoute Brasil
BREVO_TIMEOUT_MS=10000

ORS_API_KEY=your-openrouteservice-api-key

PAGSEGURO_MERCHANT_ID=ECOROUTE-DEMO
PAGSEGURO_SECRET_KEY=replace-with-demo-signature-secret

JSON_BODY_LIMIT=1mb
URLENCODED_BODY_LIMIT=1mb
AUTH_RATE_LIMIT_MAX=20
OTP_REQUEST_RATE_LIMIT_MAX=5
OTP_VERIFY_RATE_LIMIT_MAX=10
